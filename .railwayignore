# Keep railway up uploads small (<100MB) — a ~1GB working tree times out.
# Patterns are anchored with a leading slash: an unanchored `data/` also
# matches `src/data/` and breaks the image (ModuleNotFoundError).

# Local-only apps and docs (repo root only)
/mobile/
/frontend/
/docs/
/reports/
/data/

# Tooling state
/.claude/
/.git/
.pytest_cache/
__pycache__/
*.log

# Model checkpoints: ship only the best (loaders select best-by-metric anyway)
/models/tcn/*
!/models/tcn/step_001472_sharpe_5.217.pt
/models/transformer/*
!/models/transformer/step_000555_sharpe_5.201.pt
