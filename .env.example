# ─── Market Data ──────────────────────────────────────────────
POLYGON_API_KEY=your_polygon_api_key_here
# UNUSUAL_WHALES_API_KEY=  ← replaced by yfinance (free, no key needed)
NEWS_API_KEY=your_news_api_key_here
BENZINGA_API_KEY=your_benzinga_api_key_here

# ─── Broker ───────────────────────────────────────────────────
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
# Set to "paper" or "live"
ALPACA_MODE=paper
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
ALPACA_LIVE_BASE_URL=https://api.alpaca.markets

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://stockbot:stockbot@localhost:5432/stockbot
DATABASE_SYNC_URL=postgresql://stockbot:stockbot@localhost:5432/stockbot

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── AI ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Forecast email (daily pre-market forecast) ───────────────
# Optional. When unset the bot still writes reports/forecasts/*.json but
# skips sending. Gmail: create an App Password (Google Account → Security →
# 2-Step Verification → App passwords) and use it as SMTP_PASSWORD.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your_16_char_app_password
# FORECAST_EMAIL_FROM=you@gmail.com
# FORECAST_EMAIL_TO=mithunghosh404@gmail.com
# FORECAST_TICKERS=SNDK

# ─── App ──────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
