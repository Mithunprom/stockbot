# Copy this to .env.local and fill in your keys
# Get your free API key at: https://polygon.io

VITE_POLYGON_API_KEY=your_polygon_api_key_here
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: override refresh interval (ms). Default: 900000 (15 min for free tier)
# VITE_REFRESH_INTERVAL=900000
