# PyTorch / ML model checkpoints (large binaries — don't commit to git)
models/transformer/*.pt
models/tcn/*.pt
models/rl_agent/*.zip
models/rl_agent/periodic/*.zip
# Include the production sizing model
!models/rl_agent/best_sizing_ppo.zip
models/sentiment/

# Data (raw tick data can be gigabytes)
data/raw/
data/features/

# Reports (auto-generated at runtime — keep directory structure but not content)
reports/latency/*
reports/risk/*
reports/drift/*
reports/opportunities/*
!reports/latency/.gitkeep
!reports/risk/.gitkeep
!reports/drift/.gitkeep
!reports/opportunities/.gitkeep

# Staging suggestions (human-reviewed, not committed)
config/staging/
# config/ffsa_features.json IS committed (Railway fallback)

